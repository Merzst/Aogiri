@page "{id:int}"
@model Aogiri.Pages.Ads.EditModel
@{ ViewData["Title"] = "Редактировать объявление"; Layout = "_Layout"; }

<div style="max-width:800px;margin:2rem auto;padding:0 1.5rem;">
  <div class="section-title"><i class="bi bi-pencil" style="color:#8B0000;"></i> Редактировать объявление</div>
  <div class="aogiri-card">
    <div class="aogiri-card-body" style="padding:1.5rem;">
      @foreach(var err in ModelState.Values.SelectMany(v=>v.Errors)){
      <div class="alert-aogiri alert-danger-aogiri"><i class="bi bi-exclamation-circle"></i> @err.ErrorMessage</div>
      }
      <form method="post" enctype="multipart/form-data">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group-aogiri" style="grid-column:1/-1;">
            <label class="form-label-aogiri">Заголовок *</label>
            <input asp-for="Title" class="form-control-aogiri">
          </div>
          <div class="form-group-aogiri" style="grid-column:1/-1;">
            <label class="form-label-aogiri">Описание</label>
            <textarea asp-for="Description" class="form-control-aogiri" rows="5"></textarea>
          </div>
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Цена (руб.) *</label>
            <input asp-for="Price" type="number" min="0" step="0.01" class="form-control-aogiri">
          </div>
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Категория *</label>
            <select asp-for="CategoryID" class="form-control-aogiri">
              @foreach(var cat in Model.Categories){<option value="@cat.CategoryID">@cat.Name</option>}
            </select>
          </div>
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Город *</label>
            <select asp-for="LocationID" class="form-control-aogiri">
              @foreach(var loc in Model.Locations){<option value="@loc.LocationID">@loc.City</option>}
            </select>
          </div>
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Новая фотография</label>
            @if(Model.Ad?.ImageUrl != null){
            <div style="margin-bottom:0.4rem;"><img src="@Model.Ad.ImageUrl" style="height:60px;border-radius:4px;"></div>
            }
            <input asp-for="Image" type="file" accept="image/*" class="form-control-aogiri" style="padding:0.4rem;">
          </div>
        </div>
        <div class="divider"></div>
        <div style="display:flex;gap:0.8rem;justify-content:flex-end;">
          <a asp-page="/Account/Cabinet" class="btn-aogiri-outline"><i class="bi bi-x"></i> Отмена</a>
          <button type="submit" class="btn-aogiri-primary"><i class="bi bi-save"></i> Сохранить</button>
        </div>
      </form>
    </div>
  </div>
</div>
