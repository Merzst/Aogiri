@page "{id:int}"
@model Aogiri.Pages.Ads.EditModel
@{ ViewData["Title"] = "Редактировать объявление"; Layout = "_Layout"; }

<div style="max-width:800px;margin:2rem auto;padding:0 1.5rem;">
  <div class="section-title">
    <i class="bi bi-pencil" style="color:#8B0000;"></i> Редактировать объявление
  </div>
  <div class="aogiri-card">
    <div class="aogiri-card-body" style="padding:1.5rem;">
      @foreach(var err in ModelState.Values.SelectMany(v => v.Errors)){
        <div class="alert-aogiri alert-danger-aogiri">
          <i class="bi bi-exclamation-circle"></i> @err.ErrorMessage
        </div>
      }
      <form method="post" enctype="multipart/form-data">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">

          <!-- Заголовок -->
          <div class="form-group-aogiri" style="grid-column:1/-1;">
            <label class="form-label-aogiri">Заголовок <span style="color:#c0392b">*</span></label>
            <input asp-for="Title" class="form-control-aogiri" placeholder="Например: Продам iPhone 13 128GB">
          </div>

          <!-- Описание -->
          <div class="form-group-aogiri" style="grid-column:1/-1;">
            <label class="form-label-aogiri">Описание</label>
            <textarea asp-for="Description" class="form-control-aogiri" rows="5"></textarea>
          </div>

          <!-- Цена -->
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Цена (руб.) <span style="color:#c0392b">*</span></label>
            <input asp-for="Price" type="number" min="0" step="0.01" class="form-control-aogiri">
          </div>

          <!-- Тип сделки -->
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Тип сделки</label>
            <select asp-for="DealType" class="form-control-aogiri">
              <option value="">— Не указано —</option>
              <option value="Продажа">Продажа</option>
              <option value="Аренда">Аренда</option>
              <option value="Обмен">Обмен</option>
              <option value="Отдам бесплатно">Отдам бесплатно</option>
            </select>
          </div>

          <!-- Категория -->
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Категория <span style="color:#c0392b">*</span></label>
            <select asp-for="CategoryID" id="categorySelect" class="form-control-aogiri"
                    onchange="onCategoryChange(this.value)">
              <option value="">— Выберите категорию —</option>
              @foreach(var cat in Model.Categories){
                <option value="@cat.CategoryID">@cat.Name</option>
              }
            </select>
          </div>

          <!-- Подкатегория -->
          <div class="form-group-aogiri" id="subcatBlock"
               style="display:@(Model.SubcategoryID.HasValue ? "" : "none");">
            <label class="form-label-aogiri">Подкатегория</label>
            <select asp-for="SubcategoryID" id="subcategorySelect" class="form-control-aogiri">
              <option value="">— Все подкатегории —</option>
              @foreach(var sub in Model.Subcategories){
                <option value="@sub.SubcategoryID"
                        data-cat="@sub.CategoryID"
                         selected="@(Model.SubcategoryID == sub.SubcategoryID)">
                  @sub.Name
                </option>
              }
            </select>
          </div>

          <!-- Состояние -->
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Состояние</label>
            <select asp-for="Condition" class="form-control-aogiri">
              <option value="">— Не указано —</option>
              <option value="Новое">Новое</option>
              <option value="Б/у — отличное">Б/у — отличное</option>
              <option value="Б/у — хорошее">Б/у — хорошее</option>
              <option value="Б/у — удовлетворительное">Б/у — удовлетворительное</option>
            </select>
          </div>

          <!-- Город -->
          <div class="form-group-aogiri">
            <label class="form-label-aogiri">Город <span style="color:#c0392b">*</span></label>
            <select asp-for="LocationID" class="form-control-aogiri">
              @foreach(var loc in Model.Locations){
                <option value="@loc.LocationID">@loc.City (@loc.Region)</option>
              }
            </select>
          </div>

          <!-- Динамические поля по категории -->
          <div id="dynamicFields" style="grid-column:1/-1;display:none;">
            <div class="divider" style="margin:0.5rem 0;"></div>
            <div style="font-size:0.85rem;color:#888;margin-bottom:0.8rem;">
              <i class="bi bi-sliders"></i> Дополнительные характеристики
            </div>
            <div id="dynamicFieldsGrid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            </div>
          </div>

          @* ── Текущие фото ── *@
          @if(Model.ExistingImages.Any()){
          <div class="form-group-aogiri" style="grid-column:1/-1;">
            <label class="form-label-aogiri">Текущие фотографии</label>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.4rem;">
              @foreach(var img in Model.ExistingImages){
              <div style="position:relative;display:inline-block;">
                <img src="@img.ImageUrl"
                     style="width:90px;height:90px;object-fit:cover;border-radius:6px;
                            border:2px solid @(img.SortOrder==0?"#8B0000":"#333");">
                @if(img.SortOrder == 0){
                <div style="position:absolute;bottom:2px;left:50%;transform:translateX(-50%);
                            font-size:0.6rem;background:#8B0000;color:#fff;
                            border-radius:3px;padding:0 3px;white-space:nowrap;">обложка</div>
                }
                <label style="position:absolute;top:2px;right:2px;background:rgba(0,0,0,.7);
                              color:#e74c3c;border-radius:50%;width:20px;height:20px;
                              display:flex;align-items:center;justify-content:center;
                              cursor:pointer;font-size:0.7rem;"
                       title="Удалить">
                  <input type="checkbox" name="DeleteImages" value="@img.AdImageID"
                         style="display:none;" onchange="this.parentElement.style.opacity=this.checked?'0.3':'1'">
                  <i class="bi bi-x-lg"></i>
                </label>
              </div>
              }
            </div>
            <div style="font-size:0.72rem;color:#555;margin-top:4px;">
              Нажмите <i class="bi bi-x-lg" style="color:#e74c3c;"></i> на фото, чтобы пометить его на удаление
            </div>
          </div>
          }

          @* ── Новые фото ── *@
          <div class="form-group-aogiri" style="grid-column:1/-1;">
            <label class="form-label-aogiri">Добавить фотографии</label>
            <input name="NewImages" type="file" accept="image/*" multiple
                   class="form-control-aogiri" style="padding:0.4rem;"
                   onchange="previewNew(this)">
            <div id="newPreviewRow"
                 style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.6rem;"></div>
          </div>
        </div>

        <div class="divider"></div>
        <div style="display:flex;gap:0.8rem;justify-content:flex-end;">
          <a asp-page="/Account/Cabinet" class="btn-aogiri-outline">
            <i class="bi bi-x"></i> Отмена
          </a>
          <button type="submit" class="btn-aogiri-primary">
            <i class="bi bi-save"></i> Сохранить
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
// ── Данные с сервера ─────────────────────────────────────────
const CATEGORY_FIELDS   = @Html.Raw(Model.CategoryFieldsJson);
const SUBCATEGORIES     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.Subcategories.Select(s => new { id = s.SubcategoryID, categoryId = s.CategoryID, name = s.Name })
));
// Существующие атрибуты текущего объявления
const EXISTING_ATTRS    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.Ad?.Attributes?.ToDictionary(a => a.Key, a => a.Value) ?? new Dictionary<string, string>()
));
const CURRENT_CATEGORY  = @(Model.CategoryID);
const CURRENT_SUBCAT    = @(Model.SubcategoryID?.ToString() ?? "null");

// ── Инициализация при загрузке ───────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
    if (CURRENT_CATEGORY) {
        refreshSubcategories(CURRENT_CATEGORY);
        renderDynamicFields(CURRENT_CATEGORY);
    }
});

// ── Смена категории ──────────────────────────────────────────
function onCategoryChange(catId) {
    refreshSubcategories(parseInt(catId));
    renderDynamicFields(parseInt(catId));
}

function refreshSubcategories(catNum) {
    const subs       = SUBCATEGORIES.filter(s => s.categoryId === catNum);
    const subcatBlock  = document.getElementById('subcatBlock');
    const subcatSelect = document.getElementById('subcategorySelect');
    subcatSelect.innerHTML = '<option value="">— Все подкатегории —</option>';
    if (subs.length > 0) {
        subs.forEach(s => {
            const opt = document.createElement('option');
            opt.value       = s.id;
            opt.textContent = s.name;
            // восстанавливаем выбранную подкатегорию
            if (s.id === CURRENT_SUBCAT) opt.selected = true;
            subcatSelect.appendChild(opt);
        });
        subcatBlock.style.display = '';
    } else {
        subcatBlock.style.display = 'none';
    }
}

function renderDynamicFields(catId) {
    const fields    = CATEGORY_FIELDS[catId] || [];
    const container = document.getElementById('dynamicFieldsGrid');
    const wrapper   = document.getElementById('dynamicFields');
    container.innerHTML = '';

    if (fields.length === 0) { wrapper.style.display = 'none'; return; }
    wrapper.style.display = '';

    fields.forEach(f => {
        const div = document.createElement('div');
        div.className = 'form-group-aogiri';

        const label = document.createElement('label');
        label.className   = 'form-label-aogiri';
        label.textContent = f.label + (f.unit ? ` (${f.unit})` : '');
        if (f.required) label.innerHTML += ' <span style="color:#c0392b">*</span>';
        div.appendChild(label);

        let input;
        if (f.type === 'select') {
            input = document.createElement('select');
            input.className = 'form-control-aogiri';
            const blank = document.createElement('option');
            blank.value = ''; blank.textContent = '— Выберите —';
            input.appendChild(blank);
            (f.options || []).forEach(opt => {
                const o = document.createElement('option');
                o.value = opt; o.textContent = opt;
                // восстанавливаем значение
                if (EXISTING_ATTRS[f.key] === opt) o.selected = true;
                input.appendChild(o);
            });
        } else {
            input = document.createElement('input');
            input.type  = f.type === 'number' ? 'number' : 'text';
            input.className   = 'form-control-aogiri';
            input.placeholder = f.unit ? `Например: 2019` : `Введите ${f.label.toLowerCase()}`;
            if (f.type === 'number') { input.min = '0'; input.step = '1'; }
            // восстанавливаем значение
            if (EXISTING_ATTRS[f.key]) input.value = EXISTING_ATTRS[f.key];
        }
        input.name = `attr_${f.key}`;
        if (f.required) input.required = true;
        div.appendChild(input);
        container.appendChild(div);
    });
}

// ── Превью новых фото ────────────────────────────────────────
function previewNew(input) {
    const row = document.getElementById('newPreviewRow');
    row.innerHTML = '';
    [...input.files].forEach(file => {
        const reader = new FileReader();
        reader.onload = e => {
            const img = document.createElement('img');
            img.src = e.target.result;
            img.style.cssText = 'width:80px;height:80px;object-fit:cover;border-radius:6px;border:2px solid #444;';
            row.appendChild(img);
        };
        reader.readAsDataURL(file);
    });
}
</script>
}
