@page "{id:int}"
@model Aogiri.Pages.Ads.DetailModel
@{ ViewData["Title"] = Model.Ad?.Title ?? "Объявление"; Layout = "_Layout"; }

@if(Model.Ad == null){
<div class="empty-state" style="padding:5rem;">
  <i class="bi bi-exclamation-circle"></i><p>Объявление не найдено</p>
</div>
} else {
<div style="max-width:1100px;margin:2rem auto;padding:0 1.5rem;">
  <div style="display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">

    <!-- Main -->
    <div style="flex:1;min-width:0;">
      <div class="aogiri-card">
        <div class="aogiri-card-body" style="padding:1.5rem;">

          @* ═══════════════════════════════════════════════════
             ГАЛЕРЕЯ
             ═══════════════════════════════════════════════════ *@
          @{
            var imgs    = Model.Images;
            bool hasImgs = imgs.Any();
          }

          @if(hasImgs){
          <div style="margin-bottom:1.2rem;">
            <!-- Главное фото -->
            <div style="position:relative;background:#111;border-radius:8px;overflow:hidden;
                        max-height:55vh;display:flex;align-items:center;justify-content:center;">
              <img id="mainPhoto" src="@imgs[0].ImageUrl" alt="@Model.Ad.Title"
                   style="max-width:100%;max-height:55vh;object-fit:contain;display:block;">

              @if(imgs.Count > 1){
              <button onclick="changePhoto(-1)"
                      style="position:absolute;left:8px;top:50%;transform:translateY(-50%);
                             background:rgba(0,0,0,.6);border:none;color:#fff;
                             width:36px;height:36px;border-radius:50%;cursor:pointer;
                             font-size:1rem;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-chevron-left"></i>
              </button>
              <button onclick="changePhoto(1)"
                      style="position:absolute;right:8px;top:50%;transform:translateY(-50%);
                             background:rgba(0,0,0,.6);border:none;color:#fff;
                             width:36px;height:36px;border-radius:50%;cursor:pointer;
                             font-size:1rem;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-chevron-right"></i>
              </button>

              <div id="photoCounter"
                   style="position:absolute;bottom:8px;right:10px;
                          background:rgba(0,0,0,.6);color:#fff;
                          border-radius:12px;padding:2px 10px;font-size:0.78rem;">
                1 / @imgs.Count
              </div>
              }
            </div>

            @if(imgs.Count > 1){
            <div style="display:flex;gap:6px;margin-top:8px;overflow-x:auto;padding-bottom:4px;">
              @for(int i = 0; i < imgs.Count; i++){
              <img src="@imgs[i].ImageUrl"
                   onclick="selectPhoto(@i)"
                   id="thumb_@i"
                   style="width:64px;height:64px;object-fit:cover;border-radius:6px;cursor:pointer;
                          flex-shrink:0;border:2px solid @(i==0?"#8B0000":"#333");
                          transition:border-color .15s;">
              }
            </div>
            }
          </div>
          } else {
          <div style="height:200px;background:#1a1a1a;border-radius:8px;
                      display:flex;align-items:center;justify-content:center;
                      color:#444;font-size:2.5rem;margin-bottom:1.2rem;">
            <i class="bi bi-image"></i>
          </div>
          }

          <!-- Title & Price -->
          <div class="ad-detail-price">@Model.Ad.Price.ToString("N0") руб.</div>
          <h1 class="ad-detail-title" style="margin:0.5rem 0 1rem;">@Model.Ad.Title</h1>

          <!-- Meta pills -->
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
            <span class="info-pill"><i class="bi bi-grid"></i> @Model.Ad.Category.Name</span>
            @if(Model.Ad.Subcategory != null){
              <span class="info-pill"><i class="bi bi-diagram-3"></i> @Model.Ad.Subcategory.Name</span>
            }
            <span class="info-pill"><i class="bi bi-geo-alt"></i> @Model.Ad.Location.City</span>
            <span class="info-pill"><i class="bi bi-clock"></i> @Model.Ad.PublishedDate.ToString("dd.MM.yyyy")</span>
            <span class="info-pill"><i class="bi bi-eye"></i> @Model.Ad.ViewCount просмотров</span>
            @if(!string.IsNullOrEmpty(Model.Ad.Condition)){
              <span class="info-pill"><i class="bi bi-check-circle"></i> @Model.Ad.Condition</span>
            }
            @if(!string.IsNullOrEmpty(Model.Ad.DealType)){
              <span class="info-pill" style="color:#c0392b;"><i class="bi bi-tag"></i> @Model.Ad.DealType</span>
            }
            @if(Model.Ad.ExpiryDate.HasValue){
              var dLeft = (int)(Model.Ad.ExpiryDate.Value - DateTime.UtcNow).TotalDays;
              var dCol  = dLeft <= 3 ? "#e74c3c" : (dLeft <= 7 ? "#e67e22" : "#888");
              <span class="info-pill" style="color:@dCol;">
                <i class="bi bi-calendar-x"></i>
                @(dLeft > 0 ? $"Истекает через {dLeft} д." : "Истёк")
              </span>
            }
          </div>

          <!-- Status -->
          @{
            var (statusCls, statusLbl) = Model.Ad.Status switch {
              "Active"   => ("badge-active",   "Активно"),
              "Pending"  => ("badge-pending",  "На модерации"),
              "Rejected" => ("badge-rejected", "Отклонено"),
              "Inactive" => ("badge-inactive", "Неактивно"),
              _          => ("badge-draft",    "Черновик")
            };
          }
          <span class="ad-card-badge @statusCls"
                style="position:static;display:inline-block;margin-bottom:1rem;">@statusLbl</span>
          @if(Model.Ad.Status == "Rejected" && Model.Ad.RejectionReason != null){
          <div class="alert-aogiri alert-danger-aogiri">
            <i class="bi bi-x-circle"></i> Причина отклонения: @Model.Ad.RejectionReason
          </div>
          }

          <!-- Description -->
          @if(!string.IsNullOrEmpty(Model.Ad.Description)){
          <div class="divider"></div>
          <div style="font-size:0.9rem;line-height:1.7;color:#ccc;">@Model.Ad.Description</div>
          }

          @* ── Дополнительные характеристики ── *@
          @if(Model.Ad.Attributes != null && Model.Ad.Attributes.Any()){
          <div class="divider"></div>
          <div style="font-size:0.85rem;color:#888;margin-bottom:0.8rem;font-weight:600;">
            <i class="bi bi-sliders"></i> Характеристики
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.5rem;">
            @foreach(var attr in Model.Ad.Attributes){
            <div style="background:#1a1a1a;border-radius:6px;padding:0.5rem 0.8rem;border:1px solid #2a2a2a;">
              <div style="font-size:0.72rem;color:#666;margin-bottom:2px;">@attr.Key</div>
              <div style="font-size:0.88rem;color:#e8e8e8;font-weight:500;">@attr.Value</div>
            </div>
            }
          </div>
          }

          <!-- Owner actions -->
          @if(Model.IsOwner){
          <div class="divider"></div>
          <a asp-page="/Ads/Edit" asp-route-id="@Model.Ad.AdID" class="btn-aogiri-outline">
            <i class="bi bi-pencil"></i> Редактировать
          </a>
          }
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div style="width:300px;flex-shrink:0;">
      <div class="aogiri-card" style="margin-bottom:1rem;">
        <div class="aogiri-card-header"><i class="bi bi-person"></i> Продавец</div>
        <div class="aogiri-card-body" style="text-align:center;padding:1.2rem;">
          <div class="avatar-circle"
               style="margin:0 auto 0.7rem;width:50px;height:50px;font-size:1.2rem;">
            @Model.Ad.User.Name[0]
          </div>
          <div style="font-weight:600;">@Model.Ad.User.Name</div>
          <div style="font-size:0.78rem;color:#666;margin-top:2px;">
            на Aogiri с @Model.Ad.User.RegDate.ToString("yyyy")
          </div>

          @if(HttpContext.Session.GetInt32("UserId") != null && !Model.IsOwner){
          <div class="divider"></div>
          <form method="post" asp-page-handler="SendMessage">
            <input type="hidden" name="id" value="@Model.Ad.AdID">
            <textarea name="MessageText" class="form-control-aogiri" rows="3"
                      placeholder="Написать продавцу..." style="margin-bottom:0.6rem;"></textarea>
            <button type="submit" class="btn-aogiri-primary"
                    style="width:100%;justify-content:center;">
              <i class="bi bi-send"></i> Написать
            </button>
          </form>
          <div class="divider"></div>
          <form method="post" action="/Favorites/Toggle?adId=@Model.Ad.AdID"
                style="margin:0 0 0.5rem;">
            <button type="submit" class="btn-aogiri-outline"
                    style="width:100%;justify-content:center;">
              <i class="bi bi-heart@(Model.IsFavorited?"-fill":"")"></i>
              @(Model.IsFavorited ? "В избранном" : "В избранное")
            </button>
          </form>
          <a asp-page="/Ads/Report" asp-route-id="@Model.Ad.AdID"
             class="btn-aogiri-outline"
             style="width:100%;justify-content:center;display:flex;
                    color:#888;border-color:#444;font-size:0.82rem;">
            <i class="bi bi-flag"></i>&nbsp; Пожаловаться
          </a>
          }
        </div>
      </div>

      <div class="aogiri-card">
        <div class="aogiri-card-header"><i class="bi bi-geo-alt"></i> Местоположение</div>
        <div class="aogiri-card-body">
          <div style="font-size:0.9rem;color:#ccc;">
            <div style="font-weight:600;">@Model.Ad.Location.City</div>
            @if(!string.IsNullOrEmpty(Model.Ad.Location.Region)){
              <div style="color:#888;">@Model.Ad.Location.Region</div>}
            <div style="color:#666;">@Model.Ad.Location.Country</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

@section Scripts {
<script>
// ── Галерея ──────────────────────────────────────────────────
const photos  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Images.Select(i => i.ImageUrl)));
let   current = 0;

function selectPhoto(idx) {
    current = idx;
    document.getElementById('mainPhoto').src = photos[idx];
    const counter = document.getElementById('photoCounter');
    if (counter) counter.textContent = `${idx+1} / ${photos.length}`;
    document.querySelectorAll('[id^="thumb_"]').forEach((t, i) => {
        t.style.borderColor = i === idx ? '#8B0000' : '#333';
    });
}

function changePhoto(dir) {
    if (photos.length === 0) return;
    selectPhoto((current + dir + photos.length) % photos.length);
}

document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  changePhoto(-1);
    if (e.key === 'ArrowRight') changePhoto(1);
});
</script>
}
}
