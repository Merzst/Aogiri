@page
@model Aogiri.Pages.Messages.IndexModel
@{ ViewData["Title"] = "Сообщения"; Layout = "_Layout"; }

<div style="max-width:1100px;margin:2rem auto;padding:0 1.5rem;">
  <div class="section-title"><i class="bi bi-chat" style="color:#8B0000;"></i> Сообщения</div>

  <div class="messages-layout" style="display:flex;gap:1rem;height:calc(100vh - 200px);min-height:500px;">

    <!-- Список диалогов -->
    <div class="aogiri-card conv-panel" id="convPanel"
         style="width:280px;flex-shrink:0;display:flex;flex-direction:column;">
      <div class="aogiri-card-header"><i class="bi bi-people"></i> Диалоги</div>
      <div style="overflow-y:auto;flex:1;">
        @if(!Model.Conversations.Any()){
          <div class="empty-state" style="padding:2rem 1rem;">
            <i class="bi bi-chat-dots"></i><p style="font-size:0.85rem;">Нет диалогов</p>
          </div>
        }
        @foreach(var conv in Model.Conversations){
          <a class="conversation-list-item @(Model.PartnerID==conv.Partner.UserID?"active":"")"
             href="/Messages?partnerId=@conv.Partner.UserID">
            <div class="avatar-circle" style="width:38px;height:38px;font-size:0.9rem;">
              @conv.Partner.Name[0]
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:0.87rem;font-weight:600;color:#e8e8e8;">@conv.Partner.Name</div>
              <div style="font-size:0.78rem;color:#666;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                @conv.LastMessage.Text
              </div>
            </div>
            @if(conv.UnreadCount > 0){<span class="unread-badge">@conv.UnreadCount</span>}
          </a>
        }
      </div>
    </div>

    <!-- Область чата -->
    <div class="aogiri-card chat-panel @(Model.CurrentPartner!=null?"chat-active":"")"
         id="chatPanel"
         style="flex:1;display:flex;flex-direction:column;min-width:0;">

      @if(Model.CurrentPartner != null){
      <div class="aogiri-card-header" style="justify-content:space-between;flex-wrap:wrap;gap:0.4rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <button class="chat-back-btn" onclick="history.back()">
            <i class="bi bi-arrow-left"></i> Назад
          </button>
          <div class="avatar-circle" style="width:30px;height:30px;font-size:0.8rem;">
            @Model.CurrentPartner.Name[0]
          </div>
          @Model.CurrentPartner.Name
        </div>

        @* ── ИСПРАВЛЕНИЕ БАГ 1: статус партнёра, а не своего соединения ── *@
        <div style="display:flex;align-items:center;gap:5px;font-size:0.75rem;color:#555;">
          <span id="partnerDot"
                style="width:8px;height:8px;border-radius:50%;background:#555;
                       display:inline-block;transition:background .3s;"></span>
          <span id="partnerStatus">...</span>
        </div>
      </div>

      <div class="chat-container" id="chatContainer">
        @{var myId = HttpContext.Session.GetInt32("UserId");}
        @foreach(var msg in Model.CurrentMessages){
        <div>
          <div class="msg-bubble @(msg.SenderID==myId?"msg-bubble-sent":"msg-bubble-recv")">
            @if(msg.Advertisement != null){
              <div style="font-size:0.72rem;opacity:0.7;margin-bottom:3px;">
                <i class="bi bi-megaphone"></i> По объявлению: @msg.Advertisement.Title
              </div>
            }
            @msg.Text
            <span class="msg-time">@msg.SentDate.ToString("HH:mm · dd.MM")</span>
          </div>
        </div>
        }
      </div>

      <div style="padding:0.75rem;border-top:1px solid #3a3a3a;display:flex;gap:0.5rem;">
        <input id="msgInput" class="form-control-aogiri" style="flex:1;"
               placeholder="Написать сообщение..."
               onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg();}">
        <button onclick="sendMsg()" class="btn-aogiri-primary">
          <i class="bi bi-send"></i>
        </button>
      </div>

      } else {
      <div class="empty-state" style="flex:1;display:flex;flex-direction:column;
                                       align-items:center;justify-content:center;">
        <i class="bi bi-chat" style="font-size:2.5rem;color:#333;"></i>
        <p style="color:#555;margin-top:0.8rem;">Выберите диалог</p>
      </div>
      }
    </div>
  </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js" crossorigin="anonymous"></script>
<script>
const MY_ID      = @(HttpContext.Session.GetInt32("UserId") ?? 0);
const PARTNER_ID = @(Model.PartnerID ?? 0);

const chatContainer = document.getElementById('chatContainer');
const msgInput      = document.getElementById('msgInput');

if (chatContainer) chatContainer.scrollTop = chatContainer.scrollHeight;

// ── Вспомогательные функции ──────────────────────────────────
function setPartnerStatus(online) {
    const dot  = document.getElementById('partnerDot');
    const span = document.getElementById('partnerStatus');
    if (!dot || !span) return;
    dot.style.background = online ? '#2ecc71' : '#555';
    span.textContent     = online ? 'онлайн'  : 'офлайн';
}

function appendMessage(payload) {
    if (!chatContainer) return;
    const isMine = payload.senderId === MY_ID;
    const wrap = document.createElement('div');
    wrap.innerHTML = `
      <div class="msg-bubble ${isMine ? 'msg-bubble-sent' : 'msg-bubble-recv'}">
        ${escHtml(payload.text)}
        <span class="msg-time">${payload.sentDate}</span>
      </div>`;
    chatContainer.appendChild(wrap);
    chatContainer.scrollTop = chatContainer.scrollHeight;
}

function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── SignalR ──────────────────────────────────────────────────
let connection = null;

if (MY_ID > 0) {
    connection = new signalR.HubConnectionBuilder()
        .withUrl('/chatHub')
        .withAutomaticReconnect([0, 2000, 5000, 10000])
        .configureLogging(signalR.LogLevel.Warning)
        .build();

    // Получено сообщение
    connection.on('ReceiveMessage', (payload) => {
        if ((payload.senderId === PARTNER_ID && payload.receiverId === MY_ID) ||
            (payload.senderId === MY_ID      && payload.receiverId === PARTNER_ID)) {
            appendMessage(payload);
        }
    });

    // ── ИСПРАВЛЕНИЕ БАГ 1: слушаем события онлайн/офлайн ────────
    // Хаб рассылает всем — фильтруем только по партнёру
    connection.on('UserOnline',  (userId) => { if (userId === PARTNER_ID) setPartnerStatus(true);  });
    connection.on('UserOffline', (userId) => { if (userId === PARTNER_ID) setPartnerStatus(false); });

    connection.onreconnected(async () => {
        await connection.invoke('Register', MY_ID);
        // После переподключения заново проверяем статус партнёра
        if (PARTNER_ID > 0) {
            const online = await connection.invoke('IsOnline', PARTNER_ID);
            setPartnerStatus(online);
        }
    });

    connection.start()
        .then(async () => {
            // Регистрируемся
            await connection.invoke('Register', MY_ID);

            // ── Запрашиваем реальный статус партнёра ────────────
            if (PARTNER_ID > 0) {
                const online = await connection.invoke('IsOnline', PARTNER_ID);
                setPartnerStatus(online);
            }
        })
        .catch(() => setPartnerStatus(false));
}

// ── Отправка ─────────────────────────────────────────────────
function sendMsg() {
    const text = msgInput?.value.trim();
    if (!text || PARTNER_ID === 0) return;

    if (connection && connection.state === signalR.HubConnectionState.Connected) {
        connection.invoke('SendMessage', MY_ID, PARTNER_ID, text)
            .catch(err => console.error('SignalR:', err));
        msgInput.value = '';
    } else {
        fallbackSend(text);
    }
}

function fallbackSend(text) {
    const form = document.createElement('form');
    form.method = 'post';
    form.action = `/Messages?handler=Reply&partnerId=${PARTNER_ID}`;
    const token = document.querySelector('input[name="__RequestVerificationToken"]');
    if (token) form.appendChild(token.cloneNode());
    const inp = document.createElement('input');
    inp.type = 'hidden'; inp.name = 'ReplyText'; inp.value = text;
    form.appendChild(inp);
    document.body.appendChild(form);
    form.submit();
}
</script>
}
