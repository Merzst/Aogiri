<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Aogiri</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/aogiri.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/aogiri-responsive.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar-aogiri">
    <div style="max-width:1280px;margin:0 auto;padding:0 1rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">

        <!-- Логотип -->
        <a class="navbar-brand-aogiri" asp-page="/Index">
            <div class="brand-icon">
                <img src="~/images/aogiri-logo.jpg" alt="Aogiri" />
            </div>
            AOGIRI<span class="brand-dot">.</span>
        </a>

        <!-- Десктопное меню -->
        <div class="nav-desktop-links" style="flex:1;display:flex;align-items:center;gap:0.3rem;flex-wrap:wrap;">
            <a class="nav-link-aogiri" asp-page="/Index"><i class="bi bi-house"></i> Главная</a>
            @{
                var uid  = Context.Session.GetInt32("UserId");
                var role = Context.Session.GetString("UserRole");
            }
            @if (uid != null) {
            <a class="nav-link-aogiri" asp-page="/Messages/Index"><i class="bi bi-chat"></i> Сообщения</a>
            <a class="nav-link-aogiri" asp-page="/Favorites/Index"><i class="bi bi-heart"></i> Избранное</a>
            <a class="nav-link-aogiri" asp-page="/Account/Cabinet"><i class="bi bi-person"></i> Кабинет</a>
            @if (role == "Moderator" || role == "Admin") {
            <a class="nav-link-aogiri" asp-page="/Moderator/Index"><i class="bi bi-shield-check"></i> Модерация</a>
            }
            @if (role == "Admin") {
            <a class="nav-link-aogiri" asp-page="/Admin/Index"><i class="bi bi-gear"></i> Админ</a>
            }
            }
        </div>

        <!-- Десктопные кнопки справа -->
        <div class="nav-desktop-actions" style="display:flex;align-items:center;gap:0.5rem;">
            @if (uid != null) {
            <span style="color:#888;font-size:0.82rem;">@Context.Session.GetString("UserName")</span>
            <a class="btn-aogiri-outline btn-aogiri-sm" asp-page="/Ads/Create"><i class="bi bi-plus-lg"></i> Подать объявление</a>
            <form method="post" asp-page="/Account/Logout" style="margin:0;">
                <button type="submit" class="btn-aogiri-outline btn-aogiri-sm"><i class="bi bi-box-arrow-right"></i> Выйти</button>
            </form>
            } else {
            <a class="nav-link-aogiri" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Войти</a>
            <a class="btn-publish-nav" asp-page="/Account/Register"><i class="bi bi-person-plus"></i> Регистрация</a>
            }
        </div>

        <!-- Гамбургер — только мобиль -->
        <button class="nav-hamburger" id="hamburgerBtn" aria-label="Меню" onclick="toggleMobileMenu()">
            <i class="bi bi-list" id="hamburgerIcon"></i>
        </button>
    </div>

    <!-- Мобильное меню -->
    <div class="nav-mobile-menu" id="mobileMenu">
        <a class="nav-link-aogiri" asp-page="/Index"><i class="bi bi-house"></i> Главная</a>
        @if (uid != null) {
        <a class="nav-link-aogiri" asp-page="/Messages/Index"><i class="bi bi-chat"></i> Сообщения</a>
        <a class="nav-link-aogiri" asp-page="/Favorites/Index"><i class="bi bi-heart"></i> Избранное</a>
        <a class="nav-link-aogiri" asp-page="/Account/Cabinet"><i class="bi bi-person"></i> Кабинет</a>
        @if (role == "Moderator" || role == "Admin") {
        <a class="nav-link-aogiri" asp-page="/Moderator/Index"><i class="bi bi-shield-check"></i> Модерация</a>
        }
        @if (role == "Admin") {
        <a class="nav-link-aogiri" asp-page="/Admin/Index"><i class="bi bi-gear"></i> Админ</a>
        }
        <a class="btn-aogiri-primary" asp-page="/Ads/Create" style="margin-top:0.5rem;justify-content:center;">
            <i class="bi bi-plus-lg"></i> Подать объявление
        </a>
        <form method="post" asp-page="/Account/Logout" style="margin:0.4rem 0 0;">
            <button type="submit" class="btn-aogiri-outline" style="width:100%;justify-content:center;">
                <i class="bi bi-box-arrow-right"></i> Выйти (@Context.Session.GetString("UserName"))
            </button>
        </form>
        } else {
        <a class="nav-link-aogiri" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Войти</a>
        <a class="btn-publish-nav" asp-page="/Account/Register" style="margin-top:0.4rem;justify-content:center;">
            <i class="bi bi-person-plus"></i> Регистрация
        </a>
        }
    </div>
</nav>

    <div id="toast-container" style="position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;"></div>

    <script>
        // ── Гамбургер-меню ───────────────────────────────────────
        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            const icon = document.getElementById('hamburgerIcon');
            if (!menu) return;
            const isOpen = menu.classList.toggle('open');
            icon.className = isOpen ? 'bi bi-x-lg' : 'bi bi-list';
        }

        // Закрываем меню при клике вне навбара
        document.addEventListener('click', function(e) {
            const menu = document.getElementById('mobileMenu');
            const btn  = document.getElementById('hamburgerBtn');
            if (!menu || !btn) return;
            if (!menu.contains(e.target) && !btn.contains(e.target)) {
                menu.classList.remove('open');
                const icon = document.getElementById('hamburgerIcon');
                if (icon) icon.className = 'bi bi-list';
            }
        });

        // ── Toast уведомления ────────────────────────────────────
        function showToast(message, type) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast-aogiri toast-${type}`;
            const iconClass = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
            toast.innerHTML = `<i class="bi ${iconClass}"></i> <span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        @if (TempData["Success"] != null)
        {
            <text>showToast('@Html.Raw(TempData["Success"]?.ToString()?.Replace("'", "\\'"))', 'success');</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>showToast('@Html.Raw(TempData["Error"]?.ToString()?.Replace("'", "\\'"))', 'error');</text>
        }
    </script>


<main>@RenderBody()</main>

<footer class="footer-aogiri">
    <div style="max-width:1280px;margin:0 auto;padding:0 1rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
            <div>
                <div class="footer-brand">AOGIRI<span style="color:#8B0000">.</span></div>
                <div>Платформа публикации частных объявлений</div>
            </div>
            <div style="display:flex;gap:1.5rem;">
                <a href="#" style="color:#666;text-decoration:none;">Правила</a>
                <a href="#" style="color:#666;text-decoration:none;">Помощь</a>
            </div>
        </div>
        <hr class="footer-divider" />
        <div style="text-align:center;color:#444;">© 2025 Aogiri. Все права защищены.</div>
    </div>
</footer>

@RenderSection("Scripts", required: false)
</body>
</html>
