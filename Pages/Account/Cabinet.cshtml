@page
@model Aogiri.Pages.Account.CabinetModel
@{ ViewData["Title"] = "Личный кабинет"; Layout = "_Layout"; }

<div style="max-width:1280px;margin:0 auto;padding:2rem 1.5rem;">
  <div style="display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">

    <!-- ===== LEFT: Profile ===== -->
    <div style="width:280px;flex-shrink:0;">

      <!-- Avatar + info -->
      <div class="aogiri-card" style="margin-bottom:1rem;">
        <div class="aogiri-card-body" style="padding:1.5rem;text-align:center;">
          <div style="position:relative;display:inline-block;margin-bottom:1rem;">
            @if(!string.IsNullOrEmpty(Model.CurrentUser?.AvatarUrl)){
              <img src="@Model.CurrentUser.AvatarUrl" id="avatarPreview"
                   style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid #8B0000;">
            } else {
              <div class="profile-avatar-lg" id="avatarPlaceholder" style="margin:0;">
                @Model.CurrentUser?.Name?[0]
              </div>
              <img id="avatarPreview"
                   style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid #8B0000;display:none;">
            }
            <label for="avatarInput" title="Изменить фото"
                   style="position:absolute;bottom:0;right:0;width:24px;height:24px;background:#8B0000;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.7rem;color:#fff;">
              <i class="bi bi-camera"></i>
            </label>
          </div>

          <div style="font-weight:700;font-size:1rem;color:#fff;">@Model.CurrentUser?.Name</div>
          <div style="font-size:0.8rem;color:#666;margin-top:3px;">@@@Model.CurrentUser?.Login</div>
          <div style="font-size:0.78rem;color:#555;margin-top:2px;">
            с @Model.CurrentUser?.RegDate.ToString("MMMM yyyy")
          </div>
          @{
            var roleLabel = Model.CurrentUser?.Role switch {
              "Admin" => "Администратор", "Moderator" => "Модератор", _ => "Пользователь"
            };
            var roleColor = Model.CurrentUser?.Role switch {
              "Admin" => "#c9a84c", "Moderator" => "#3498db", _ => "#8B3333"
            };
          }
          <div style="margin-top:0.5rem;font-size:0.78rem;color:@roleColor;font-weight:600;">@roleLabel</div>

          @if(!string.IsNullOrEmpty(Model.CurrentUser?.AvatarUrl)){
          <form method="post" asp-page-handler="RemoveAvatar" style="margin-top:0.5rem;">
            <button type="submit" class="btn-aogiri-outline btn-aogiri-sm" style="font-size:0.72rem;">
              <i class="bi bi-trash"></i> Удалить фото
            </button>
          </form>
          }
        </div>
      </div>

      <!-- Stats -->
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.5rem;margin-bottom:1rem;">
        <div class="stat-box"><div class="stat-num">@Model.ActiveCount</div><div class="stat-label">Активных</div></div>
        <div class="stat-box"><div class="stat-num">@Model.PendingCount</div><div class="stat-label">На мод.</div></div>
        <div class="stat-box"><div class="stat-num">@Model.TotalViews</div><div class="stat-label">Просм.</div></div>
      </div>

      <!-- Edit profile form -->
      <div class="aogiri-card" style="margin-bottom:1rem;">
        <div class="aogiri-card-header"><i class="bi bi-pencil"></i> Редактировать профиль</div>
        <div class="aogiri-card-body">
          <form method="post" asp-page-handler="UpdateProfile" enctype="multipart/form-data">
            <input type="file" id="avatarInput" asp-for="Avatar" accept="image/*"
                   style="display:none;" onchange="previewAvatar(this)">

            <div class="form-group-aogiri">
              <label class="form-label-aogiri">Имя / Псевдоним</label>
              <input asp-for="Name" class="form-control-aogiri">
            </div>
            <div class="form-group-aogiri">
              <label class="form-label-aogiri">Телефон</label>
              <input asp-for="Phone" class="form-control-aogiri">
            </div>
            <div class="form-group-aogiri">
              <label class="form-label-aogiri">Email</label>
              <input asp-for="Email" type="email" class="form-control-aogiri" placeholder="необязательно">
            </div>

            <div id="avatarPreviewBlock" style="display:none;margin-bottom:0.8rem;">
              <div style="font-size:0.75rem;color:#888;margin-bottom:0.3rem;">Новая аватарка:</div>
              <img id="avatarNewPreview"
                   style="width:60px;height:60px;border-radius:50%;object-fit:cover;border:2px solid #8B0000;">
            </div>

            <button type="submit" class="btn-aogiri-primary" style="width:100%;justify-content:center;">
              <i class="bi bi-save"></i> Сохранить
            </button>
          </form>
        </div>
      </div>

      @* ─────────────────────────────────────────────────────── *@
      @* НОВОЕ: Форма смены пароля                               *@
      @* ─────────────────────────────────────────────────────── *@
      <div class="aogiri-card">
        <div class="aogiri-card-header"><i class="bi bi-shield-lock"></i> Сменить пароль</div>
        <div class="aogiri-card-body">
          <form method="post" asp-page-handler="ChangePassword">
            <div class="form-group-aogiri">
              <label class="form-label-aogiri">Текущий пароль</label>
              <input asp-for="OldPassword" type="password" class="form-control-aogiri"
                     placeholder="••••••••" autocomplete="current-password">
            </div>
            <div class="form-group-aogiri">
              <label class="form-label-aogiri">Новый пароль</label>
              <input asp-for="NewPassword" type="password" class="form-control-aogiri"
                     placeholder="Минимум 4 символа" autocomplete="new-password">
            </div>
            <div class="form-group-aogiri">
              <label class="form-label-aogiri">Подтверждение</label>
              <input asp-for="ConfirmPassword" type="password" class="form-control-aogiri"
                     placeholder="Повторите новый пароль" autocomplete="new-password">
            </div>
            <button type="submit" class="btn-aogiri-outline" style="width:100%;justify-content:center;">
              <i class="bi bi-key"></i> Изменить пароль
            </button>
          </form>
        </div>
      </div>
      @* ─────────────────────────────────────────────────────── *@

    </div>

    <!-- ===== RIGHT: Ads ===== -->
    <div style="flex:1;min-width:0;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <div class="section-title" style="margin-bottom:0;flex:1;">
          <i class="bi bi-megaphone" style="color:#8B0000;"></i>
          Мои объявления (@Model.MyAds.Count)
        </div>
        <a asp-page="/Ads/Create" class="btn-aogiri-primary btn-aogiri-sm">
          <i class="bi bi-plus-lg"></i> Подать
        </a>
      </div>

      @if(!Model.MyAds.Any()){
        <div class="empty-state">
          <i class="bi bi-megaphone"></i>
          <p>У вас ещё нет объявлений</p>
          <a asp-page="/Ads/Create" class="btn-aogiri-primary"><i class="bi bi-plus-lg"></i> Подать первое</a>
        </div>
      } else {
        <div class="aogiri-card">
          <table class="aogiri-table">
            <thead><tr>
              <th>Объявление</th><th>Категория</th><th>Цена</th>
              <th>Статус</th><th>Просм.</th>
              @* НОВОЕ: колонка срока *@
              <th>Истекает</th>
              <th>Действия</th>
            </tr></thead>
            <tbody>
            @foreach(var ad in Model.MyAds){
            <tr>
              <td>
                <a asp-page="/Ads/Detail" asp-route-id="@ad.AdID"
                   style="color:#e8e8e8;text-decoration:none;font-weight:500;">@ad.Title</a>
                <div style="font-size:0.75rem;color:#666;">
                  @ad.Location.City · @ad.PublishedDate.ToString("dd.MM.yyyy")
                </div>
              </td>
              <td style="color:#888;font-size:0.85rem;">@ad.Category.Name</td>
              <td style="color:#c0392b;font-weight:700;">@ad.Price.ToString("N0") р.</td>
              <td>
                @{
                  var (cls, lbl) = ad.Status switch {
                    "Active"   => ("badge-active",   "Активно"),
                    "Pending"  => ("badge-pending",  "На модерации"),
                    "Rejected" => ("badge-rejected", "Отклонено"),
                    "Inactive" => ("badge-inactive", "Неактивно"),
                    _          => ("badge-draft",    "Черновик")
                  };
                }
                <span class="ad-card-badge @cls" style="position:static;display:inline-block;">@lbl</span>
                @if(ad.Status == "Rejected" && ad.RejectionReason != null){
                  <div style="font-size:0.72rem;color:#c06060;margin-top:2px;">@ad.RejectionReason</div>
                }
              </td>
              <td style="color:#666;font-size:0.85rem;">@ad.ViewCount</td>

              @* ─── НОВОЕ: срок публикации ─── *@
              <td style="font-size:0.78rem;">
                @if(ad.ExpiryDate.HasValue){
                  var days = (int)(ad.ExpiryDate.Value - DateTime.UtcNow).TotalDays;
                  var col  = days <= 3 ? "#e74c3c" : (days <= 7 ? "#e67e22" : "#666");
                  if(days > 0){
                    <span style="color:@col;">@days д.</span>
                  } else {
                    <span style="color:#e74c3c;">Истёк</span>
                  }
                } else {
                  <span style="color:#444;">—</span>
                }
              </td>

              <td>
                <div style="display:flex;gap:0.3rem;flex-wrap:wrap;">
                  <a asp-page="/Ads/Edit" asp-route-id="@ad.AdID"
                     class="btn-aogiri-outline btn-aogiri-sm" title="Редактировать">
                    <i class="bi bi-pencil"></i>
                  </a>

                  @* ─── НОВОЕ: Продлить ─── *@
                  @if(ad.Status == "Active" || ad.Status == "Inactive"){
                  <form method="post" asp-page-handler="RenewAd" style="margin:0;">
                    <input type="hidden" name="adId" value="@ad.AdID">
                    <button type="submit" class="btn-aogiri-outline btn-aogiri-sm"
                            title="Продлить на 30 дней"
                            style="color:#2ecc71;border-color:#2ecc71;">
                      <i class="bi bi-arrow-clockwise"></i>
                    </button>
                  </form>
                  }

                  <form method="post" asp-page-handler="DeactivateAd" style="margin:0;">
                    <input type="hidden" name="adId" value="@ad.AdID">
                    <button type="submit" class="btn-aogiri-outline btn-aogiri-sm"
                            title="@(ad.Status=="Active"?"Деактивировать":"Активировать")">
                      <i class="bi bi-@(ad.Status=="Active"?"pause":"play")"></i>
                    </button>
                  </form>

                  <form method="post" asp-page-handler="DeleteAd" style="margin:0;"
                        onsubmit="return confirm('Удалить объявление «@ad.Title»?')">
                    <input type="hidden" name="adId" value="@ad.AdID">
                    <button type="submit" class="btn-aogiri-danger btn-aogiri-sm" title="Удалить">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            }
            </tbody>
          </table>
        </div>
      }
    </div>
  </div>
</div>

@section Scripts {
<script>
function previewAvatar(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            const src = e.target.result;
            const np  = document.getElementById('avatarNewPreview');
            if (np) { np.src = src; }
            document.getElementById('avatarPreviewBlock').style.display = 'block';
            const prev = document.getElementById('avatarPreview');
            const phld = document.getElementById('avatarPlaceholder');
            if (prev) { prev.src = src; prev.style.display = 'block'; }
            if (phld) { phld.style.display = 'none'; }
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}
